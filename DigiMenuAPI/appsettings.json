  "Email": {
    "Provider": "SendGrid",
    "FromEmail": "noreply@digimenu.cr",
    "FromName": "DigiMenu",
    "AppUrl": "https://app.digimenu.cr",

    "SendGridApiKey": "SG.REEMPLAZAR_CON_API_KEY_REAL",

    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "User": "tucuenta@gmail.com",
      "Password": "REEMPLAZAR_CON_APP_PASSWORD",
      "EnableSsl": true
    },

    "Outbox": {
      "IntervalSeconds": 30,
      "MaxRetries": 5,
      "BatchSize": 20
    }
  },

  "Jwt": {
    "Key": "TU_CLAVE_SECRETA_MINIMO_32_CARACTERES_AQUI!!",
    "Issuer": "DigiMenuAPI",
    "Audience": "DigiMenuClients",
    "ExpiresHours": "8"
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:4200",
    "https://tudominio.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                              "Warning",
        "Microsoft.AspNetCore":                   "Warning",
        "Microsoft.EntityFrameworkCore":          "Warning",
        "Microsoft.EntityFrameworkCore.Database": "Warning",
        "System":                                 "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "DigiMenuAPI"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId,-36}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/digimenu-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj} | App={Application}{NewLine}{Exception}"
        }
      }
    ],
    "Filter": [
      {
        "Name": "ByExcludingMatching",
        "Args": { "expression": "RequestPath like '/health%'" }
      }
    ]
  },
  "AllowedHosts": "*"
}